rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Helper: Check if user is admin
    // ============================================================
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)).data.role == 'admin';
    }

    // ============================================================
    // User data — private to owner, readable by admins
    // ============================================================
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
      }
    }

    // ============================================================
    // Allowed users — admin management + self-read for auth check
    // ============================================================
    match /allowedUsers/{email} {
      // Users can read their own record (for auth check)
      allow read: if request.auth != null && request.auth.token.email == email;
      // Users can create their own record (during invite redemption)
      allow create: if request.auth != null && request.auth.token.email == email;
      // Users can update their own record (lastActive, etc)
      allow update: if request.auth != null && request.auth.token.email == email;
      // Admins can read all
      allow read: if isAdmin();
    }

    // ============================================================
    // Invites — readable by anyone (for validation), writable by admins
    // ============================================================
    match /invites/{inviteId} {
      // Anyone can read (needed for invite link validation before sign-in)
      allow read: if true;
      // Admins can create invites
      allow create: if isAdmin();
      // Authenticated users can update (to mark as used during redemption)
      allow update: if request.auth != null;
    }

    // ============================================================
    // Feedback — writable by authenticated users, readable by admins
    // ============================================================
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    // ============================================================
    // Deny everything else by default
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
